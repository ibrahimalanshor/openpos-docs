---
import Container from './Container.astro';

const { title, subtitle, color = 'light' } = Astro.props;

const colorClassList = color === 'dark' ? 'bg-gray-50' : '';
---

<section class={`${colorClassList}`}>
  <Container class="py-20 space-y-12">
    <div class="text-center space-y-4">
      <h1 class="font-bold text-gray-900 text-3xl tracking-tight">
        {title}
      </h1>
      <p class="text-gray-500 text-lg max-w-lg mx-auto">
        {subtitle}
      </p>
    </div>

    <slot />
  </Container>
</section>
