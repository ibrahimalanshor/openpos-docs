---
import Default from '../../components/layouts/Default.astro';
import Container from '../../components/base/Container.astro';
import Card from '../../components/base/Card.astro';
import Section from '../../components/base/Section.astro';
import IconBadge from '../../components/base/IconBadge.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
---

<Default title="Panduang Menggunakan Aplikasi Kasir" titleAppend>
  <Container>
    <Section
      title="Panduan Menggunakan Aplikasi Kasir OpenPos"
      subtitle="Tutorial menggunakan aplikasi OpenPos, cara menginstal, menggunakan fitur, dsb."
      lead="Panduan"
      leadIcon="tabler:book"
    >
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          docs.map((doc) => (
            <Card>
              <IconBadge icon={doc.data.icon} />
              <div class="space-y-2">
                <h2 class="font-semibold text-gray-900 text-lg">
                  {doc.data.title}
                </h2>
                <p class="text-gray-500">{doc.data.summary}</p>
              </div>
            </Card>
          ))
        }
      </div>
    </Section>
  </Container>
</Default>
